# ===============================
# Solana SOL/USDC Agent Team MVP
# Default: devnet + simulated
# ===============================

# --- Core mode ---
NETWORK_LABEL=devnet
RPC_URL=https://api.devnet.solana.com
EXECUTION_MODE=simulated
DRY_RUN=1
UI_PORT=8787

# --- Wallet ---
# This build uses a locally generated dev wallet record stored in state/generated-wallet.json
# Run: npm run wallet:new
AIRDROP_ON_WALLET=0
AIRDROP_SOL=1

# --- Pair (fixed for this MVP) ---
BASE_ASSET_SYMBOL=SOL
QUOTE_ASSET_SYMBOL=USDC

# --- Price source ---
# auto = Jupiter price first, fallback to mock walk
# jupiter = Jupiter price only
# mock = local deterministic walk, good for offline smoke tests
PRICE_MODE=auto
MOCK_START_PRICE=180
MOCK_DRIFT_BPS=18
MOCK_VOL_BPS=45

# --- Loop / windows ---
LOOP_SEC=15
SIGNAL_MIN_SEC=300
COOLDOWN_SEC=900
DECISION_WINDOW_SEC=60
MAX_TRADES_PER_DAY=8

# --- Bull bot (more bullish) ---
BULL_DIP_PCT=0.8
BULL_RIP_PCT=1.5
BULL_BUY_USDC=1
BULL_SELL_SOL=0.01

# --- Bear bot (more risk-off) ---
BEAR_DIP_PCT=1.5
BEAR_RIP_PCT=0.5
BEAR_BUY_USDC=1
BEAR_SELL_SOL=0.01

# --- Risk / execution guardrails ---
MIN_EXPECTED_EDGE_BPS=20
MIN_TRADE_USDC=1
MAX_NOTIONAL_USDC=8
DAILY_NOTIONAL_LIMIT_USDC=50
MIN_SOL_RESERVE=0.05
STALE_SIGNAL_SEC=180
# Inventory cap: refuse new BUYs when SOL value already >= this % of total portfolio.
# Prevents the bot from spending all USDC in a downtrend. 60 = stop buying once 60% of
# portfolio is SOL. Set to 100 to disable.
MAX_SOL_ALLOCATION_PCT=60

# EMA trend filter: only BUY when EMA(fast) is rising tick-to-tick.
TREND_FILTER_ENABLED=1
EMA_PERIOD=20

# Dual EMA regime gate: only BUY when fast EMA > slow EMA (medium-term uptrend confirmed).
# Prevents entering in sustained bear markets. RSI oversold overrides this gate.
# Sweep-optimal: EMA_PERIOD=20, REGIME_EMA_SLOW=50
REGIME_FILTER_ENABLED=1
REGIME_EMA_SLOW=45

# Profit target: auto-sell entire SOL position when unrealized gain >= PROFIT_TARGET_PCT.
# Guarantees every auto-closed position is profitable. Set to 0 to disable.
# Sweep-optimal: PROFIT_TARGET_PCT=2.0
PROFIT_TARGET_ENABLED=1
PROFIT_TARGET_PCT=3.0

# ATR-based dynamic thresholds (advanced, default off).
# When enabled, replaces fixed DIP/RIP% with ATR(period)-scaled values so thresholds
# self-calibrate to current market volatility.
USE_ATR_THRESHOLDS=0
ATR_PERIOD=14
ATR_DIP_MULT=1.0
ATR_RIP_MULT=0.7
ATR_MIN_DIP_PCT=0.1
ATR_MIN_RIP_PCT=0.1

# RSI filter (default ON).
# BUY logic: allowed when (EMA rising) OR (RSI < RSI_OVERSOLD).
# The oversold override is the crash-buy feature — when RSI drops below threshold,
# buys are re-enabled even in a declining EMA trend. RSI_OVERSOLD=40 is the
# sweep-optimal value (wider crash window, more buys in deep dips).
# SELL: also triggers early when RSI > RSI_OVERBOUGHT and price is above anchor.
RSI_ENABLED=1
RSI_PERIOD=14
RSI_OVERSOLD=40
RSI_OVERBOUGHT=70

# Stop-loss: force-exit SOL position when unrealized loss on the SOL bag
# exceeds STOP_LOSS_PCT from average entry. Prevents catastrophic drawdowns
# in flash crashes or sustained bear markets.
STOP_LOSS_ENABLED=1
STOP_LOSS_PCT=20

# --- Simulated execution defaults (devnet test-first) ---
SIM_START_USDC=1000
SIM_START_SOL=5
SIM_FEE_BPS=30
SIM_SLIPPAGE_BPS=8

# --- Sweeper ---
# MANDATORY: You must set a real wallet address here for EXECUTION_MODE=real
PROFIT_WALLET=SimulatedProfitWallet11111111111111111111111
USDC_RESERVE=300
USDC_PROFIT_MIN=25
PROFIT_SWEEP_PCT=0.50
SWEEP_EVERY_SEC=600
MIN_SOL_FOR_SWEEP=0.05

# --- Solana mint addresses ---
SOL_MINT=So11111111111111111111111111111111111111112
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# --- Price cache freshness ---
STALE_PRICE_SEC=60

# --- Shadow mode (paper trading with real price feeds) ---
SHADOW_MODE=0
SHADOW_QUOTE_ON_TRADE=1

# --- Alerts (Discord webhook) ---
ALERT_WEBHOOK_URL=
ALERT_ON_TRADE=0
ALERT_ON_ERROR=0

# --- Real execution limits (only used if EXECUTION_MODE=real) ---
REAL_MAX_TRADES_PER_DAY=5
REAL_MAX_NOTIONAL_USDC=25
REAL_DAILY_NOTIONAL_LIMIT_USDC=50

# --- Real execution (requires @solana/web3.js) ---
# Set one of these:
# PRIVATE_KEY=<base58 encoded ed25519 keypair>
# or leave empty to use state/generated-wallet.json
PRIVATE_KEY=

# --- Wealth-V2 sell-side fixes ---
BULL_STRONG_REGIME_PCT=10
BULL_TRAIL_GIVE_PCT=25
BULL_MIN_SOL_HOLD=0
BULL_PROPORTIONAL_SELLS=0
MIN_NET_EDGE_BPS=0
BULL_MAX_NOTIONAL_USDC=25
